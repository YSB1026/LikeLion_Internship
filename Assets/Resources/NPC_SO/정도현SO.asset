  npcName: "\uC815\uB3C4\uD604"
  currentDialogueFile: "Day1_\uC815\uB3C4\uD604"
  personality: "\uC870\uC9C1 \uC548\uC815\uC774 \uAC1C\uC778 \uC9C4\uC2E4\uBCF4\uB2E4
    \uC911\uC694. \uBB38\uC81C\uB97C \uAD00\uB9AC \uAC00\uB2A5\uD55C \uBC94\uC704\uB85C
    \uCD95\uC18C\uD558\uB824\uB294 \uACBD\uD5A5. \uC9C4\uC2E4\uC744 \uB9D0\uD558\uC9C0
    \uC54A\uC9C0\uB9CC \uCD5C\uC18C\uD55C \uAC70\uC9D3\uB9D0\uB85C \uC65C\uACE1\uD558\uC9C0
    \uC54A\uC74C. \uB9D0 \uAE38\uC774 \uC9E7\uC74C, \uAC10\uC815 \uC808\uC81C, \uC911\uB9BD
    \uC720\uC9C0."
  speechExamples:
  - "\uC11C\uB958\uC0C1\uC73C\uB860 \uBB38\uC81C\uC5C6\uC2B5\uB2C8\uB2E4."
  - "\uADF8\uAC8C \uC911\uC694\uD558\uC8E0."
  - "\uC808\uCC28\uB300\uB85C \uCC98\uB9AC\uD588\uC2B5\uB2C8\uB2E4."
  - "\uC6B4\uC601\uC0C1 \uBB38\uC81C\uC5C6\uC2B5\uB2C8\uB2E4."
  roleDescription: "\uC5F0\uAD6C\uC18C \uC6B4\uC601 \uAD00\uB9AC\uC790. \uC0AC\uAC74
