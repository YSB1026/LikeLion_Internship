    \uD1B5\uC81C."
  hiddenTruth: "\uC778\uB825 \uBD80\uC871\uC73C\uB85C \uC810\uAC80 \uC0DD\uB7B5 \uC9C0\uC2DC."
  knowledgeLevel: "\uC0AC\uAC74 \uC804\uB0A0 \uC548\uC804 \uC810\uAC80 \uBCF4\uACE0\uC11C
